# ── Discord Bot ───────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ── Security (AES-256-GCM key derivation) ────────────────────
# Random string >= 32 chars. If lost, all saved tokens become unrecoverable.
MASTER_SECRET=change_me_to_a_random_string_at_least_32_chars

# ── Database ─────────────────────────────────────────────────
DB_PATH=data/quest_bot.db

# ── Logging ──────────────────────────────────────────────────
DEBUG=false
LOG_PROGRESS=true
LOG_DIR=logs

# ── Quest Engine ─────────────────────────────────────────────
POLL_INTERVAL=60
HEARTBEAT_INTERVAL=20
AUTO_ACCEPT=true
MAX_PARALLEL_PLAY=6
MAX_CONCURRENT_TASKS=10
TASK_TIMEOUT_HOURS=6

# ── Rate Limits ──────────────────────────────────────────────
MAX_RUNS_PER_HOUR=5
COMMAND_COOLDOWN=10

# ── Scheduler ────────────────────────────────────────────────
AUTO_RUN_INTERVAL_DAYS=2
SCHEDULER_CHECK_HOURS=1
SCHEDULER_JITTER_MINS=30
